<nav style="background: var(--color-bg-surface, #ffffff); border-bottom: 1px solid var(--color-border, #e5e7eb);" class="sticky top-0 z-30">
  <div class="max-w-5xl mx-auto px-6 h-16 flex items-center justify-between">
    <a href="/{{ lang }}/" class="flex items-center" style="color: var(--color-accent);">
      {% if site.logo %}
        <img src="{{ site.logo }}" alt="{{ site.name }}" class="h-9 max-w-40 object-contain" />
      {% else %}
        <span class="font-bold text-lg tracking-tight">{{ site.name }}</span>
      {% endif %}
    </a>

    <!-- Desktop links -->
    <div class="hidden md:flex items-center gap-6 text-sm">
      {% for link in nav.byLang[lang] %}
        {% if link.children and link.children.length %}
          <!-- Dropdown (opens on hover; parent label navigates if it has a URL) -->
          <div class="relative" data-dropdown>
            <div class="flex items-center gap-0.5">
              {% if link.type === 'builtin' or link.type === 'page' %}
                <a href="/{{ lang }}{{ link.url }}" data-nav-href="/{{ lang }}{{ link.url }}" class="transition-colors" style="color: var(--color-muted);" onmouseout="this.dataset.active!=='1'&&(this.style.color='var(--color-muted)')">{{ link.labels[lang] if (link.labels and link.labels[lang]) else link.label }}</a>
              {% elif link.type === 'external' %}
                <a href="{{ link.url }}" class="transition-colors" style="color: var(--color-muted);" target="_blank" rel="noopener noreferrer">{{ link.labels[lang] if (link.labels and link.labels[lang]) else link.label }}</a>
              {% else %}
                <span style="color: var(--color-muted);">{{ link.labels[lang] if (link.labels and link.labels[lang]) else link.label }}</span>
              {% endif %}
              <button data-dropdown-toggle class="flex items-center px-1 py-1 transition-colors cursor-pointer" style="color: var(--color-muted);" aria-label="Open menu">
                <svg class="w-3 h-3 transition-transform duration-150" data-chevron fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
                </svg>
              </button>
            </div>
            <div class="absolute left-0 top-full mt-1.5 min-w-44 rounded-lg shadow-lg hidden z-40 py-1"
                 style="background: var(--color-bg-surface); border: 1px solid var(--color-border);"
                 data-dropdown-menu>
              {% for child in link.children %}
                {% if child.type === 'divider' %}
                  <div style="border-top: 1px solid var(--color-border); margin: 4px 8px;"></div>
                {% else %}
                  {% if child.type === 'builtin' or child.type === 'page' %}
                    <a href="/{{ lang }}{{ child.url }}"
                       class="block px-4 py-2 text-sm transition-colors"
                       style="color: var(--color-text);"
                       onmouseover="this.style.background='var(--color-border)'"
                       onmouseout="this.style.background=''">
                      {{ child.labels[lang] if (child.labels and child.labels[lang]) else child.label }}
                    </a>
                  {% else %}
                    <a href="{{ child.url }}"
                       class="block px-4 py-2 text-sm transition-colors"
                       style="color: var(--color-text);"
                       target="_blank" rel="noopener noreferrer"
                       onmouseover="this.style.background='var(--color-border)'"
                       onmouseout="this.style.background=''">
                      {{ child.labels[lang] if (child.labels and child.labels[lang]) else child.label }}
                    </a>
                  {% endif %}
                {% endif %}
              {% endfor %}
            </div>
          </div>
        {% else %}
          {% if link.type === 'builtin' or link.type === 'page' %}
            <a href="/{{ lang }}{{ link.url }}" data-nav-href="/{{ lang }}{{ link.url }}" class="transition-colors" style="color: var(--color-muted);" onmouseout="this.dataset.active!=='1'&&(this.style.color='var(--color-muted)')">{{ link.labels[lang] if (link.labels and link.labels[lang]) else link.label }}</a>
          {% else %}
            <a href="{{ link.url }}" class="transition-colors" style="color: var(--color-muted);" target="_blank" rel="noopener noreferrer">{{ link.labels[lang] if (link.labels and link.labels[lang]) else link.label }}</a>
          {% endif %}
        {% endif %}
      {% endfor %}

      <!-- Language switcher (rendered only when >1 language configured) -->
      {% if config.languages | length > 1 %}
        <div class="relative" data-lang-switcher>
          <button class="flex items-center gap-1 text-xs uppercase tracking-wider" style="color: var(--color-muted);" data-lang-toggle>
            {{ lang }}
            <svg class="w-3 h-3 transition-transform duration-150" data-chevron fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
            </svg>
          </button>
          <div class="absolute right-0 top-full mt-1 rounded shadow-md min-w-20 hidden" style="background: var(--color-bg-surface); border: 1px solid var(--color-border);" data-lang-menu>
            {% for l in config.languages %}
              {% if l.code !== lang %}
                <a href="/{{ l.code }}/" class="block px-4 py-2 text-sm uppercase" style="color: var(--color-text);" onmouseover="this.style.background='var(--color-border)'" onmouseout="this.style.background=''">{{ l.code }}</a>
              {% endif %}
            {% endfor %}
          </div>
        </div>
      {% endif %}
    </div>

    <!-- Mobile hamburger -->
    <button class="md:hidden p-2" style="color: var(--color-muted);" data-nav-toggle aria-label="Open menu">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
      </svg>
    </button>
  </div>

  <!-- Mobile menu -->
  <div class="md:hidden hidden" style="border-top: 1px solid var(--color-border);" data-mobile-menu>
    <div class="px-6 py-4 space-y-3 text-sm">
      {% for link in nav.byLang[lang] %}
        {% if link.children and link.children.length %}
          <!-- Mobile accordion (label navigates; only chevron toggles children) -->
          <div data-mobile-dropdown>
            <div class="flex items-center justify-between gap-2 py-0.5">
              {% if link.type === 'builtin' or link.type === 'page' %}
                <a href="/{{ lang }}{{ link.url }}" data-nav-href="/{{ lang }}{{ link.url }}" class="flex-1" style="color: var(--color-text);">{{ link.labels[lang] if (link.labels and link.labels[lang]) else link.label }}</a>
              {% elif link.type === 'external' %}
                <a href="{{ link.url }}" class="flex-1" style="color: var(--color-text);" target="_blank" rel="noopener noreferrer">{{ link.labels[lang] if (link.labels and link.labels[lang]) else link.label }}</a>
              {% else %}
                <span class="flex-1" style="color: var(--color-text);">{{ link.labels[lang] if (link.labels and link.labels[lang]) else link.label }}</span>
              {% endif %}
              <button data-mobile-dropdown-toggle class="p-1 shrink-0" style="color: var(--color-muted);" aria-label="Toggle submenu">
                <svg class="w-3.5 h-3.5 transition-transform duration-150" data-chevron fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
                </svg>
              </button>
            </div>
            <div class="hidden pl-3 mt-2 space-y-2" data-mobile-dropdown-menu style="border-left: 2px solid var(--color-border);">
              {% for child in link.children %}
                {% if child.type === 'divider' %}
                  <div style="border-top: 1px solid var(--color-border);"></div>
                {% else %}
                  {% if child.type === 'builtin' or child.type === 'page' %}
                    <a href="/{{ lang }}{{ child.url }}" class="block py-0.5" style="color: var(--color-muted);">
                      {{ child.labels[lang] if (child.labels and child.labels[lang]) else child.label }}
                    </a>
                  {% else %}
                    <a href="{{ child.url }}" class="block py-0.5" style="color: var(--color-muted);" target="_blank" rel="noopener noreferrer">
                      {{ child.labels[lang] if (child.labels and child.labels[lang]) else child.label }}
                    </a>
                  {% endif %}
                {% endif %}
              {% endfor %}
            </div>
          </div>
        {% else %}
          {% if link.type === 'builtin' or link.type === 'page' %}
            <a href="/{{ lang }}{{ link.url }}" data-nav-href="/{{ lang }}{{ link.url }}" class="block" style="color: var(--color-text);">{{ link.label }}</a>
          {% else %}
            <a href="{{ link.url }}" class="block" style="color: var(--color-text);" target="_blank" rel="noopener noreferrer">{{ link.label }}</a>
          {% endif %}
        {% endif %}
      {% endfor %}
      {% if config.languages | length > 1 %}
        <div class="flex items-center flex-wrap gap-3" style="border-top: 1px solid var(--color-border); padding-top: 0.75rem;">
          <svg class="w-3.5 h-3.5 shrink-0" style="color: var(--color-muted);" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
            <circle cx="12" cy="12" r="10"/>
            <path stroke-linecap="round" stroke-linejoin="round" d="M2 12h20M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
          </svg>
          {% for l in config.languages %}
            {% if l.code !== lang %}
              <a href="/{{ l.code }}/" class="text-xs uppercase" style="color: var(--color-muted);">{{ l.code }}</a>
            {% endif %}
          {% endfor %}
        </div>
      {% endif %}
    </div>
  </div>
</nav>
