{%- set cfg = block.config -%}
{%- set source = cfg.source or "nav" -%}
{%- set parentKey = cfg.parent_key or "" -%}
{%- set layout = cfg.layout or "vertical" -%}
{%- set linkColor = cfg.link_color or "var(--color-muted)" -%}
{%- set sourceLinks = footer.byLang[lang] if source === "footer" else nav.byLang[lang] -%}
{%- set renderLinks = [] -%}
{% if parentKey %}
  {%- set parent = null -%}
  {% for l in sourceLinks %}
    {% if l.label === parentKey %}
      {%- set parent = l -%}
    {% endif %}
  {% endfor %}
  {% if parent and parent.children %}
    {%- set renderLinks = parent.children -%}
  {% endif %}
{% else %}
  {%- set renderLinks = sourceLinks -%}
{% endif %}
{% if renderLinks | length %}
  <ul class="{% if layout === 'horizontal' %}flex flex-wrap gap-4{% elif layout === 'grid' %}grid grid-cols-2 gap-2{% else %}space-y-2{% endif %} text-sm">
    {% for item in renderLinks %}
      {% if item.type !== "divider" %}
        <li>
          {% if item.type === "builtin" or item.type === "page" %}
            <a href="/{{ lang }}{{ item.url }}" style="color:{{ linkColor }};" onmouseover="this.style.color='var(--color-text)'" onmouseout="this.style.color='{{ linkColor }}'">{{ item.labels[lang] if (item.labels and item.labels[lang]) else item.label }}</a>
          {% else %}
            <a href="{{ item.url }}" target="_blank" rel="noopener noreferrer" style="color:{{ linkColor }};" onmouseover="this.style.color='var(--color-text)'" onmouseout="this.style.color='{{ linkColor }}'">{{ item.labels[lang] if (item.labels and item.labels[lang]) else item.label }}</a>
          {% endif %}
        </li>
      {% endif %}
    {% endfor %}
  </ul>
{% endif %}
