{%- set cc = b.config -%}

{# Size presets #}
{%- set _size = cc.size if cc.size else "md" -%}
{%- set _py = "py-[10px]" -%}
{%- set _px = "px-[22px]" -%}
{%- set _fs = "text-[15px]" -%}
{%- if _size === "sm" %}{%- set _py = "py-[6px]" -%}{%- set _px = "px-[14px]" -%}{%- set _fs = "text-[13px]" -%}
{%- elif _size === "lg" %}{%- set _py = "py-[14px]" -%}{%- set _px = "px-[32px]" -%}{%- set _fs = "text-[18px]" -%}
{%- endif -%}

{# Font weight #}
{%- set _fw = "font-semibold" -%}
{%- if cc.fontWeight === "normal" %}{%- set _fw = "font-normal" -%}
{%- elif cc.fontWeight === "medium" %}{%- set _fw = "font-medium" -%}
{%- elif cc.fontWeight === "bold" %}{%- set _fw = "font-bold" -%}
{%- endif -%}

{# Border radius #}
{%- set _br = cc.borderRadius if cc.borderRadius else 6 -%}

{# Accent fallback color (CSS variable always defined in site) #}
{%- set _accent = "var(--color-accent)" -%}

{# Button anchor classes #}
{%- set _btnCls = ["inline-block", _py, _px, _fs, _fw, "rounded-[" + _br + "px]", "cursor-pointer", "no-underline", "leading-[1.25]", "transition-opacity", "duration-150", "border-2", "border-solid"] -%}
{%- set _variant = cc.variant if cc.variant else "filled" -%}
{%- if _variant === "outline" -%}
  {%- set _btnCls = (_btnCls.push("bg-transparent"), _btnCls) -%}
  {%- set _btnCls = (_btnCls.push("text-[" + (cc.textColor if cc.textColor else (cc.bgColor if cc.bgColor else _accent)) + "]"), _btnCls) -%}
  {%- set _btnCls = (_btnCls.push("border-[" + (cc.borderColor if cc.borderColor else (cc.bgColor if cc.bgColor else _accent)) + "]"), _btnCls) -%}
{%- elif _variant === "ghost" -%}
  {%- set _btnCls = (_btnCls.push("bg-transparent"), _btnCls) -%}
  {%- set _btnCls = (_btnCls.push("text-[" + (cc.textColor if cc.textColor else (cc.bgColor if cc.bgColor else _accent)) + "]"), _btnCls) -%}
  {%- set _btnCls = (_btnCls.push("border-transparent"), _btnCls) -%}
{%- else -%}
  {%- set _btnCls = (_btnCls.push("bg-[" + (cc.bgColor if cc.bgColor else _accent) + "]"), _btnCls) -%}
  {%- set _btnCls = (_btnCls.push("text-[" + (cc.textColor if cc.textColor else "#fff") + "]"), _btnCls) -%}
  {%- set _btnCls = (_btnCls.push("border-transparent"), _btnCls) -%}
{%- endif -%}

{# Text align on wrapper #}
{%- set _align = cc.align if cc.align else "left" -%}
{%- set _alignCls = "text-left" -%}
{%- if _align === "center" %}{%- set _alignCls = "text-center" -%}
{%- elif _align === "right" %}{%- set _alignCls = "text-right" -%}
{%- endif -%}

{# Wrapper classes — alignment + spacing #}
{%- set _wCls = [_alignCls] -%}
{%- set _wCls = (_wCls.push("pt-" + (cc.paddingTop if cc.paddingTop else 0)), _wCls) -%}
{%- set _wCls = (_wCls.push("pb-" + (cc.paddingBottom if cc.paddingBottom else 0)), _wCls) -%}
{%- set _wCls = (_wCls.push("pl-" + (cc.paddingLeft if cc.paddingLeft else 0)), _wCls) -%}
{%- set _wCls = (_wCls.push("pr-" + (cc.paddingRight if cc.paddingRight else 0)), _wCls) -%}
{%- set _mt = cc.marginTop if cc.marginTop else 0 -%}
{%- if _mt is number and _mt < 0 -%}{%- set _wCls = (_wCls.push("-mt-" + (_mt | abs)), _wCls) -%}
{%- else -%}{%- set _wCls = (_wCls.push("mt-" + _mt), _wCls) -%}{%- endif -%}
{%- set _mb = cc.marginBottom if cc.marginBottom else 0 -%}
{%- if _mb is number and _mb < 0 -%}{%- set _wCls = (_wCls.push("-mb-" + (_mb | abs)), _wCls) -%}
{%- else -%}{%- set _wCls = (_wCls.push("mb-" + _mb), _wCls) -%}{%- endif -%}
{%- set _ml = cc.marginLeft if cc.marginLeft else 0 -%}
{%- if _ml is number and _ml < 0 -%}{%- set _wCls = (_wCls.push("-ml-" + (_ml | abs)), _wCls) -%}
{%- else -%}{%- set _wCls = (_wCls.push("ml-" + _ml), _wCls) -%}{%- endif -%}
{%- set _mr = cc.marginRight if cc.marginRight else 0 -%}
{%- if _mr is number and _mr < 0 -%}{%- set _wCls = (_wCls.push("-mr-" + (_mr | abs)), _wCls) -%}
{%- else -%}{%- set _wCls = (_wCls.push("mr-" + _mr), _wCls) -%}{%- endif -%}

<div class="{{ _wCls | join(' ') }}">
  <a{% if cc.elementId %} id="{{ cc.elementId }}"{% endif %}
     href="{{ cc.href if cc.href else '#' }}"
     target="{{ cc.target if cc.target else '_self' }}"
     class="{{ _btnCls | join(' ') }}"{% if cc.customStyle %} style="{{ cc.customStyle }}"{% endif %}>{{ cc.label if cc.label else "Button" }}</a>
</div>
