{% set featuredArticles = articles.byLang[lang] | selectattr("is_featured") | list %}
{% if featuredArticles | length %}
<section class="max-w-5xl mx-auto px-6 py-10">
  <h2 class="text-2xl font-bold mb-6" style="color: var(--color-text);">{{ b.config.title | default("Featured") }}</h2>
  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    {% for article in featuredArticles | limit(b.config.max_count | default(4)) %}
      {% set article = article %}
      {% include "partials/article-card.njk" %}
    {% endfor %}
  </div>
</section>
{% endif %}
