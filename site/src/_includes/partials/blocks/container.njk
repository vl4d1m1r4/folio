{%- set cc = b.config -%}
{%- set containerChildren = b.children -%}

{%- set _dir = "flex-row" if cc.direction !== "col" else "flex-col" -%}
{%- set _wrap = " flex-wrap" if cc.wrap === "wrap" else "" -%}
{%- set _w = "w-full max-w-5xl mx-auto" if cc.width === "w-page" else (cc.width if cc.width else "w-full") -%}
{%- set _h = (" " + cc.height) if cc.height and cc.height !== "h-auto" else "" -%}

{%- set _jus = "justify-start" -%}
{%- if cc.justify === "center" %}{%- set _jus = "justify-center" -%}
{%- elif cc.justify === "end" %}{%- set _jus = "justify-end" -%}
{%- elif cc.justify === "between" %}{%- set _jus = "justify-between" -%}
{%- endif -%}

{%- set _ali = "items-start" -%}
{%- if cc.align === "center" %}{%- set _ali = "items-center" -%}
{%- elif cc.align === "end" %}{%- set _ali = "items-end" -%}
{%- elif cc.align === "stretch" %}{%- set _ali = "items-stretch" -%}
{%- endif -%}

{%- if cc.gapX is defined and cc.gapX is not none %}{%- set _gx = cc.gapX -%}{%- else %}{%- set _gx = 4 -%}{%- endif -%}
{%- if cc.gapY is defined and cc.gapY is not none %}{%- set _gy = cc.gapY -%}{%- else %}{%- set _gy = 4 -%}{%- endif -%}
{%- set _gap = ("gap-" + _gx) if _gx === _gy else ("gap-x-" + _gx + " gap-y-" + _gy) -%}

{%- if cc.paddingTop is defined and cc.paddingTop is not none %}{%- set _pt = cc.paddingTop -%}{%- else %}{%- set _pt = 6 -%}{%- endif -%}
{%- if cc.paddingBottom is defined and cc.paddingBottom is not none %}{%- set _pb = cc.paddingBottom -%}{%- else %}{%- set _pb = 6 -%}{%- endif -%}
{%- if cc.paddingLeft is defined and cc.paddingLeft is not none %}{%- set _pl = cc.paddingLeft -%}{%- else %}{%- set _pl = 6 -%}{%- endif -%}
{%- if cc.paddingRight is defined and cc.paddingRight is not none %}{%- set _pr = cc.paddingRight -%}{%- else %}{%- set _pr = 6 -%}{%- endif -%}
{%- if _pt === _pb and _pl === _pr and _pt === _pl -%}
  {%- set _pad = "p-" + _pt -%}
{%- elif _pt === _pb and _pl === _pr -%}
  {%- set _pad = "py-" + _pt + " px-" + _pl -%}
{%- else -%}
  {%- set _pad = "pt-" + _pt + " pb-" + _pb + " pl-" + _pl + " pr-" + _pr -%}
{%- endif -%}

{%- set _mt = cc.marginTop if cc.marginTop else 0 -%}
{%- set _mb = cc.marginBottom if cc.marginBottom else 0 -%}
{%- set _ml = cc.marginLeft if cc.marginLeft else 0 -%}
{%- set _mr = cc.marginRight if cc.marginRight else 0 -%}
{%- if _mt === _mb and _ml === _mr and _mt === _ml -%}
  {%- set _mar = ("m-" + _mt) if _mt > 0 else "" -%}
{%- elif _mt === _mb and _ml === _mr -%}
  {%- set _mar = ("my-" + _mt + " mx-" + _ml) -%}
{%- else -%}
  {%- set _mar = ("mt-" + _mt + " mb-" + _mb + " ml-" + _ml + " mr-" + _mr) -%}
{%- endif -%}

{# Extra Tailwind classes for visual properties #}
{%- set _xCls = [] -%}
{%- if cc.backgroundColor %}{%- set _xCls = (_xCls.push("bg-[" + cc.backgroundColor + "]"), _xCls) -%}{%- endif -%}
{%- if cc.backgroundImage -%}
  {%- set _xCls = (_xCls.push("bg-[url('" + cc.backgroundImage + "')]"), _xCls) -%}
  {%- set _bgSize = cc.backgroundSize if cc.backgroundSize else "cover" -%}
  {%- if _bgSize === "cover" %}{%- set _xCls = (_xCls.push("bg-cover"), _xCls) -%}
  {%- elif _bgSize === "contain" %}{%- set _xCls = (_xCls.push("bg-contain"), _xCls) -%}
  {%- elif _bgSize === "auto" %}{%- set _xCls = (_xCls.push("bg-auto"), _xCls) -%}
  {%- else %}{%- set _xCls = (_xCls.push("bg-[size:" + _bgSize + "]"), _xCls) -%}{%- endif -%}
  {%- set _bgPos = cc.backgroundPosition if cc.backgroundPosition else "center" -%}
  {%- if _bgPos === "center" %}{%- set _xCls = (_xCls.push("bg-center"), _xCls) -%}
  {%- elif _bgPos === "top" %}{%- set _xCls = (_xCls.push("bg-top"), _xCls) -%}
  {%- elif _bgPos === "bottom" %}{%- set _xCls = (_xCls.push("bg-bottom"), _xCls) -%}
  {%- elif _bgPos === "left" %}{%- set _xCls = (_xCls.push("bg-left"), _xCls) -%}
  {%- elif _bgPos === "right" %}{%- set _xCls = (_xCls.push("bg-right"), _xCls) -%}
  {%- else %}{%- set _xCls = (_xCls.push("bg-[position:" + _bgPos + "]"), _xCls) -%}{%- endif -%}
  {%- set _xCls = (_xCls.push("bg-no-repeat"), _xCls) -%}
{%- endif -%}
{%- if cc.borderRadius and cc.borderRadius > 0 %}{%- set _xCls = (_xCls.push("rounded-[" + cc.borderRadius + "px]"), _xCls) -%}{%- endif -%}
{%- if cc.textColor %}{%- set _xCls = (_xCls.push("text-[" + cc.textColor + "]"), _xCls) -%}{%- endif -%}
{%- set _bgStyle = cc.customStyle if cc.customStyle else "" -%}

<div {% if cc.elementId %}id="{{ cc.elementId }}"{% endif %} class="relative flex {{ _dir }}{{ _wrap }} {{ _w }}{{ _h }} {{ _jus }} {{ _ali }} {{ _gap }} {{ _pad }} {{ _mar }} {{ _xCls | join(' ') }}"
     {% if _bgStyle %}style="{{ _bgStyle }}"{% endif %}>
  {%- if cc.backgroundImage and cc.backgroundOverlay %}
    <div class="absolute inset-0 pointer-events-none" style="background:{{ cc.backgroundOverlay }};{% if cc.borderRadius and cc.borderRadius > 0 %}border-radius:{{ cc.borderRadius }}px;{% endif %}" aria-hidden="true"></div>
  {%- endif %}
  {%- set _innerW = "w-auto" if cc.width === "w-auto" else "w-full" -%}
  {%- set _prevInContainer = _inContainer -%}
  {%- set _inContainer = true -%}
  <div class="relative flex {{ _dir }}{{ _wrap }} {{ _innerW }} h-full {{ _jus }} {{ _ali }} {{ _gap }}" style="min-width:0;">
  {%- for child in containerChildren %}
    {%- if child.visible !== false %}
      {%- set b = child %}
      {%- set block = b -%}
      {%- if child.type === "hero" %}{%- include "partials/blocks/hero.njk" %}
      {%- elif child.type === "featured-articles" %}{%- include "partials/blocks/featured-articles.njk" %}
      {%- elif child.type === "latest-articles" %}{%- include "partials/blocks/latest-articles.njk" %}
      {%- elif child.type === "cta-band" %}{%- include "partials/blocks/cta-band.njk" %}
      {%- elif child.type === "rich-text" %}{%- include "partials/blocks/rich-text.njk" %}
      {%- elif child.type === "image-text" %}{%- include "partials/blocks/image-text.njk" %}
      {%- elif child.type === "testimonials" %}{%- include "partials/blocks/testimonials.njk" %}
      {%- elif child.type === "newsletter" %}{%- include "partials/blocks/newsletter.njk" %}
      {%- elif child.type === "container" %}{%- include "partials/blocks/container.njk" %}
      {%- elif child.type === "text" %}{%- include "partials/blocks/text.njk" %}
      {%- elif child.type === "image" %}{%- include "partials/blocks/image.njk" %}
      {%- elif child.type === "button" %}{%- include "partials/blocks/button.njk" %}
      {%- elif child.type === "nav-links" %}{%- include "partials/blocks/nav-links.njk" %}
      {%- elif child.type === "subnav-links" %}{%- include "partials/blocks/subnav-links.njk" %}
      {%- elif child.type === "single-nav-item" %}{%- include "partials/blocks/single-nav-item.njk" %}
      {%- elif child.type === "social-links" %}{%- include "partials/blocks/social-links.njk" %}
      {%- elif child.type === "single-social-link" %}{%- include "partials/blocks/single-social-link.njk" %}
      {%- endif %}
    {%- endif %}
  {%- endfor %}
  </div>
  {%- set _inContainer = _prevInContainer -%}
</div>
