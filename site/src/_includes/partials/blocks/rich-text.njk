{%- if _inContainer -%}
<div class="prose prose-neutral max-w-none w-full" style="color: var(--color-text);">
  {{ b.config.content | safe }}
</div>
{%- else -%}
<section class="max-w-5xl mx-auto px-6 py-10" style="color: var(--color-text);">
  <div class="prose prose-neutral max-w-none">
    {{ b.config.content | safe }}
  </div>
</section>
{%- endif -%}
