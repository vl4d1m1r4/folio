<section class="relative overflow-hidden"
  {% if b.config.bg_image %}
    style="background: url('{{ b.config.bg_image }}') center/cover no-repeat;"
  {% endif %}>
  {% if b.config.bg_image %}
    <div class="absolute inset-0" style="background: rgba(0,0,0,0.45);"></div>
  {% endif %}
  <div class="relative max-w-5xl mx-auto px-6 py-20 text-center">
    <h1 class="text-5xl font-extrabold tracking-tight mb-5 leading-tight" style="color: {{ 'white' if b.config.bg_image else 'var(--color-text)' }};">
      {{ b.config.headline | default(site.name) }}
    </h1>
    {% if b.config.subheadline %}
      <p class="text-xl max-w-2xl mx-auto" style="color: {{ 'rgba(255,255,255,0.85)' if b.config.bg_image else 'var(--color-muted)' }};">{{ b.config.subheadline }}</p>
    {% endif %}
    {% if b.config.cta_url %}
      <div class="mt-8">
        <a href="{{ b.config.cta_url }}" rel="noopener noreferrer"
           class="inline-block px-8 py-4 text-white font-semibold text-lg transition-colors"
           style="background: var(--color-accent, #1a56db); border-radius: var(--radius-button, 8px);">
          {{ b.config.cta_label | default("Learn more") }}
        </a>
      </div>
    {% endif %}
  </div>
</section>
