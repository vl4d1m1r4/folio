# Folio — environment variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

# ── Required ──────────────────────────────────────
# Random secret used to sign JWT tokens. Generate with:
#   openssl rand -hex 32
JWT_SECRET=change_me_to_a_random_secret

# ── Optional: paths ───────────────────────────────
DB_PATH=./blog.db
PORT=8080
UPLOAD_DIR=./uploads

# Path to site/build.sh — override if you moved the site directory.
# SITE_BUILD_SCRIPT=../site/build.sh

# ── Optional: email (contact form notifications) ──
# Leave all blank to disable email sending.
# MS Graph (Azure / Microsoft 365):
# MS_GRAPH_TENANT_ID=
# MS_GRAPH_CLIENT_ID=
# MS_GRAPH_CLIENT_SECRET=
# MS_GRAPH_SENDER=noreply@yourdomain.com

# ── Optional: analytics ───────────────────────────
# GoatCounter self-hosted instance:
# GOATCOUNTER_URL=https://stats.yourdomain.com/count
# GOATCOUNTER_SCRIPT_URL=//stats.yourdomain.com/count.js
